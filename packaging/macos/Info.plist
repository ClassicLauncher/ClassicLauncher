<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  jpackage merges this file into the generated .app bundle's Info.plist via --resource-dir.

  Key additions over jpackage's default Info.plist:
    • CFBundleURLTypes  — registers the classiclauncher:// URL scheme with the OS
    • LSMultipleInstancesProhibited — prevents macOS from launching a second instance;
                                      Apple Events deliver the URI to the existing one instead
    • LSMinimumSystemVersion — macOS 10.14+ required (Desktop.setOpenURIHandler needs 10.14+)
-->
<plist version="1.0">
<dict>
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>ClassicLauncher Protocol</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>classiclauncher</string>
            </array>
        </dict>
    </array>

    <key>LSMultipleInstancesProhibited</key>
    <true/>

    <key>LSMinimumSystemVersion</key>
    <string>10.14</string>
</dict>
</plist>
